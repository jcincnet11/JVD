# Public site URL — used for OpenGraph metadataBase, sitemap, JSON-LD canonicals.
# Defaults to https://john-vincent-digital.vercel.app if unset.
NEXT_PUBLIC_SITE_URL=https://john-vincent-digital.vercel.app

# Formspree form hash ID (the 8-char value after /f/ in your Formspree dashboard URL).
# Defaults to the production form if unset.
NEXT_PUBLIC_FORMSPREE_ID=xrerbdlw

# Sentry — leave unset locally to disable error reporting.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
